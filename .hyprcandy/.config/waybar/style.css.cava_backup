/* ────────────────────────────────────────────────────────────┤ window ├───
*/
#window {
  border-radius: 30px;
  margin-right: 6px;
  margin-left: 0px;
}

/* ───────────────────────────────────────────────────────────┤ tray ├───
*/
#tray {
  color: @primary;
  background: linear-gradient(180deg, @inverse_primary, @scrim);
  margin-right: 6px;
  border-radius: 30px;
  padding-left: 4px;
  padding-right: 4px;
  padding-top: 3px;
  padding-bottom: 3px;
}

#tray:hover {
  color: @primary;
  background: linear-gradient(180deg, @inverse_primary, @scrim)
}

/* ──────────────────────────────────────────────────────────┤ tray popovers ├───
*/

/* Tray popover windows */
#tray popover,
window.popup {
  color: @primary;
  background: @on_primary;
  border-radius: 12px;
  font-size: 11px;
  padding: 10px;
  margin-top: 8px;
  font-family: "JetBrainsMono Nerd Font";
  font-weight: normal;
}

/* Tray popover labels */
#tray popover,
window.popup label {
  color: @primary;
  font-size: 11px;
  padding: 4px 4px;
  min-height: 10px;
  padding-top: 8px;
  padding-bottom: 8px;
}

/* Tray popover menu items */
#tray popover,
window.popup menuitem {
  color: @primary;
  border-radius: 8px;
}

/* ───────────────────────────────────────────────────────┤ SywaNC ├───
*/

