}

/* ──────────────────────────────────────────────────────────┤ wallpaper ├───
*/

#custom-wallpaper {
  color: @primary;
  background: linear-gradient(180deg, @inverse_primary, @scrim);
  margin-right: 1px;
  border-radius: 30px;
  padding-left: 6px;
  padding-right: 8px;
}

#custom-wallpaper:hover {
  color: @primary;
  background: linear-gradient(0deg, @inverse_primary, @scrim)
}

/* ──────────────────────────────────────────┤ toggles island ├───
*/
#toggles {
  background: linear-gradient(180deg, @inverse_primary, @scrim);
  border-radius: 30px;
}

/* ──────────────────────────────────────────┤ switch island ├───
*/
#switch {
  background: linear-gradient(180deg, @inverse_primary, @scrim);
  margin-left: 6px;
  border-radius: 30px;
}

/* ──────────────────────────────────────────┤ media island ├───
*/
#media {
  background: linear-gradient(180deg, @inverse_primary, @scrim);
  margin-left: 6px;
  border-radius: 30px;
}

/* ───────────────────────────────────────────────────────────┤ font sizes ├───
*/
/*
  NOTE: Be careful when changing font sizes, as they can affect alignment.

  Try adjusting whole numbers first, then refine with decimals.

  If you increase or decrease a value, make the same change to all properties
  in this section to keep the layout consistent.
*/

* {
  font-family: "JetBrainsMono Nerd Font";
  font-size: 11px;
  font-weight: bold;
}

tooltip label,
#window label,
#mpris {
  font-weight: normal;
  font-size: 10px;
}

/* ─────────────────────────────────────────────────────┤ hover transitions ├───
   Smooth colour + gradient transitions on all interactive waybar elements.
   Placed at end to avoid interfering with sed line-targeted rules above.
   transition: color + background animate together over 300ms ease-in-out,
   giving a clockwise/anticlockwise feel as the gradient direction reverses.
*/
#custom-overview,
#custom-wallpaper,
#custom-distro,
#custom-rofi,
#custom-weather,
#custom-player,
#custom-wifi,
#custom-update,
#custom-notification,
#idle_inhibitor,
#bluetooth,
#tray,
#power-profiles-daemon,
#clock.date,
#clock.time,
#mpris,
#battery,
#custom-system-monitor,
#custom-media-player,
#custom-power {
  transition: color 300ms ease-in-out,
              background 300ms ease-in-out,
              background-color 300ms ease-in-out;
}
