@import "colors.css";
@import "theme.css";
/* @import "animation.css"; */

/* ───────────────────────────────────────────────────────────────┤ global ├───
*/
* {
  min-height: 0;
  border: none;
  margin: 0;
  padding: 0;
}

/* ──────────────────────────────────────────────────────────┤ drop shadow ├───
*/
window#waybar {
  background: none;
  /*border: 2px solid @on_primary_fixed_variant; @primary_fixed_dim;*/
  border-radius: 20.0px;
}

/* ───────────────────────────────────────────────────────────┤ background ├───
*/
window#waybar > box {
  background: @blur_background;
  margin-top: 0.0px;
  margin-left: 12.0px;
  margin-right: 12.0px;
  margin-bottom: 0.0px;
  border-radius: 20.0px;
  padding: 4.0px;
  border: 2px solid @on_primary_fixed_variant;
}

/* ─────────────────────────────────────────────────────────────┤ tooltips ├───
*/
tooltip {
  background: @on_primary;
  border: 2px solid @inverse_primary;
  border-radius: 4px;
}

tooltip label {
  color: @primary;
  margin: 0.0px;
}

/* ───────────────────────────────────────────────────────────┤ workspaces ├───
*/

#workspaces {
  background: linear-gradient(180deg, @inverse_primary, @scrim);
  padding-left: 2px;
  padding-right: 2px;
  border-radius: 20px;
}

#workspaces button {
  color: @secondary_container;
  transition: none;
  margin-right: 2px;
  margin-left: 2px;
}

#workspaces button:hover {
  color: @primary;
  background: transparent;
  text-shadow: none;
}

#workspaces button.active {
  /*color: @on_primary;
  background: @primary_fixed_dim;*/
  color: @primary;
  background: transparent;
}

#workspaces button.active:hover {
  color: @primary;
  color: @primary_container;
}

/* Occupied workspace (persistent with windows but not focused) */
#workspaces button.persistent:not(.active):not(.empty) {
  color: @primary;
  background: transparent;
}

#workspaces button.persistent:not(.active):not(.empty):hover {
  color: @primary;
  color: @primary_container;
}

/* Urgent workspace (has urgent/notification windows) */
#workspaces button.urgent {
  color: @critical;
}

/* ──────────────────────────────────────────────────────────┤ overview ├───
*/

#custom-overview {
  color: @primary;
  background: linear-gradient(180deg, @inverse_primary, @scrim);
  margin-right: 1px;
  border-radius: 30px;
  padding-left: 6px;
  padding-right: 8px;
}

#custom-overview:hover {
  color: @primary;
  background: linear-gradient(0deg, @inverse_primary, @scrim)
}

/* ───────────────────────────────────────────────────────────┤ media info ├───
*/
#mpris {
  color: @primary;
  background: linear-gradient(180deg, @inverse_primary, @scrim);
  margin-left: 0px;
  padding-left: 1px;
  padding-right: 4px;
  border-radius: 30px;
}

#mpris:hover {
  color: @primary;
  background: linear-gradient(0deg, @inverse_primary, @scrim)
}

/* ──────────────────────────────────────────────────────────────┤ cava-left ├───
*/

#custom-cava-left {
  color: @primary;
  background: transparent;
  border-radius: 30px;
  margin-right: 0px;
  padding-left: 8px;
  padding-right: 8px;
  font-weight: normal;
  transition: all 0.3s ease;
}

/* When cava is hidden (no media playing) */
#custom-cava-left.cava-hidden {
  padding: 0;
  margin: 0;
  opacity: 0;
}

/* When cava is active (media playing) */
#custom-cava-left.cava-active {
  opacity: 1;
}

#custom-cava-left.cava-silent {
    opacity: 0.6;
}

/* ─────────────────────────────────────────────────────────────────┤ date ├───
*/

#clock.date {
  color: @primary;
  background: linear-gradient(180deg, @inverse_primary, @scrim);
  margin-left: 6px;
  margin-right: 2px;
  border-radius: 30px;
  padding-left: 6px;
  padding-right: 6px;
}

#clock.date:hover {
  color: @primary;
  background: linear-gradient(0deg, @inverse_primary, @scrim)
}

/* ──────────────────────────────────────────────────────────┤ distro icon ├───
*/

#custom-distro {
  font-size: 14px;
  color: @primary;
  /*background: linear-gradient(180deg, @inverse_primary, @scrim);*/
  border-radius: 30px;
  padding-left: 5.5px;
  padding-right: 8.5px;
  margin-left: 0px;
  margin-right: 0px;
}

#custom-distro:hover {
  color: @primary;
  /*background: linear-gradient(0deg, @inverse_primary, @scrim)*/
}

/* ─────────────────────────────────────────────────────────────────┤ time ├───
*/

#clock.time {
