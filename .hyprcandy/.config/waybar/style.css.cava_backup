  background: linear-gradient(0deg, @inverse_primary, @scrim)
}

/* ────────────────────────────────────────────────┤ system-monitor ├───
*/
#custom-system-monitor {
  color: @primary;
  background: linear-gradient(180deg, @inverse_primary, @scrim);
  margin-left: 0px;
  border-radius: 30px;
